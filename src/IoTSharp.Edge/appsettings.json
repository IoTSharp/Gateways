{
  "GatewayStorage": {
    "ConnectionString": "Data Source=gateways.db"
  },
  "EdgeReporting": {
    "Enabled": false,
    "RuntimeType": "gateway",
    "HeartbeatIntervalSeconds": 30,
    "RetryDelaySeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
