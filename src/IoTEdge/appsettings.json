{
  "GatewayStorage": {
    "ConnectionString": "Data Source=gateways.db"
  },
  "EdgeReporting": {
    "Enabled": false,
    "RuntimeType": "gateway",
    "HeartbeatIntervalSeconds": 30,
    "RetryDelaySeconds": 5
  },
  "LocalCollection": {
    "Enabled": true,
    "ApplyOnStartup": true,
    "CacheUpstreamConfigurations": true,
    "TemplatePath": "local-collection.docker.json",
    "FileName": "local-collection.json",
    "DefaultUpdatedBy": "本地配置"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
